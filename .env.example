# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
APP_NAME="Admin Dashboard API"
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:secret@localhost:5432/admin_dashboard

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── Redis (session/token revocation cache) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true
